# Build output
/memdb
/build/

# Coverage reports (repo root and nested under any sub-package — the
# pprof capture tests in server/, replication/, etc. may write to a
# local coverage/ directory when run from their own package directory).
/coverage/
**/coverage/
coverage.out
coverage.html

# SQLite files generated during development / testing
*.db
*.db.wal
*.db.zst
*.db.enc

# Test artifacts
*.test
*.out

# Go workspace files (local developer overrides — not committed)
go.work
go.work.sum
